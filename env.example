# CORS 代理服务环境变量配置
# 复制此文件为 .env.local 并填入实际值

# WebDAV 服务器配置
WEBDAV_BASE_URL=https://dav.jianguoyun.com/dav/

# CORS 配置
CORS_ALLOW_ORIGIN=*
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PROPFIND,MKCOL,MOVE,COPY
CORS_ALLOW_HEADERS=Authorization,Content-Type,Depth,If-None-Match,Etag
CORS_EXPOSE_HEADERS=Etag,DAV
CORS_MAX_AGE=86400
CORS_CREDENTIALS=false

# 请求配置
REQUEST_TIMEOUT=30000
USER_AGENT=AISP-CORS-Proxy/1.0

# 速率限制配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# 日志配置
NODE_ENV=development
