{
  "name": "growatt-openapi-docs",
  "version": "0.1.0",
  "description": "Growatt OpenAPI documentation site rendered from markdown SSOT and deployable to Cloudflare Pages.",
  "private": true,
  "keywords": [
    "growatt",
    "openapi",
    "documentation",
    "nextjs",
    "cloudflare-pages"
  ],
  "author": "AISP Team",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "npx serve out -l 3000",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "docs:lint:growatt": "node scripts/lint-growatt-docs.mjs",
    "docs:test:growatt": "jest --runInBand __tests__/growatt-link-rewriter.test.ts __tests__/growatt-docs.test.ts __tests__/growatt-codes-basic-auth.test.ts",
    "docs:check": "npm run docs:lint:growatt && npm run docs:test:growatt"
  },
  "dependencies": {
    "mermaid": "^11.12.3",
    "js-yaml": "^4.1.0",
    "next": "15.5.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.2",
    "jest": "^30.1.2",
    "jest-environment-node": "^30.1.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
